{
  "project": "Termux Sensor API",
  "version": "2.0",
  "device": {
    "model": "Honor 7 (PLK-AL10)",
    "android": "5.0.2",
    "architecture": "arm64-v8a"
  },
  "software": {
    "termux": "v0.79",
    "termux_api": "Git debug",
    "python": "3.10.13"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 9999,
    "script": "/sdcard/simple_sensor_server.py",
    "test_script": "/sdcard/test_server.py"
  },
  "adb": {
    "path": "D:\\工作日常\\服务器搭建\\荣耀手机刷机\\工具软件\\platform-tools\\adb.exe",
    "device_id": "D8YDU15A14002124",
    "port_forward": "tcp:9999 tcp:9999"
  },
  "api": {
    "base_url": "http://127.0.0.1:9999",
    "endpoints": {
      "health": "/health",
      "sensors": "/sensors",
      "sensor": "/sensor/{type}",
      "tts": "/tts?text={text}",
      "battery": "/battery"
    },
    "sensor_types": [
      "accelerometer",
      "gyroscope",
      "light",
      "magnetic",
      "pressure",
      "temperature",
      "proximity",
      "gravity",
      "linear_acceleration",
      "rotation_vector",
      "orientation"
    ]
  },
  "automation": {
    "input_delay": 0.5,
    "execution_wait": 3,
    "screenshot_path": "/sdcard/",
    "space_replacement": "%s"
  },
  "keycodes": {
    "back": 4,
    "home": 3,
    "enter": 66,
    "del": 67,
    "vol_up": 24,
    "vol_down": 25
  },
  "performance": {
    "startup_time": "< 1s",
    "response_time": "< 500ms",
    "memory": "~20MB",
    "cpu": "< 5%",
    "max_rate": "10Hz"
  }
}
